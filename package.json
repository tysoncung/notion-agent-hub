  "author": "Tyson Cung",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@notionhq/client": "^2.2.15",
    "openai": "^4.78.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
