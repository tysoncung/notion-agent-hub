  "description": "AI Agent Hub for Notion — orchestrate AI agents through Notion databases with human-in-the-loop approval. Built with MCP.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "notion-agent-hub": "dist/index.js"
  },
  "scripts": {
